[
{{- $first := true -}}
{{- range .Site.AllPages -}}
  {{- if and (not .Draft) (or (eq .Kind "page") (eq .Kind "section")) -}}

    {{- if not $first }},{{ end -}}
    {{- $first = false -}}

    {
      "title": {{ .Title | jsonify }},
      "permalink": {{ .Permalink | jsonify }},
      "description": {{ .Description | jsonify }},
      "content": {{ .Plain | strings.Truncate 300 | jsonify }},
      "lang": {{ .Language.Lang | jsonify }}
    }

  {{- end -}}
{{- end -}}
]